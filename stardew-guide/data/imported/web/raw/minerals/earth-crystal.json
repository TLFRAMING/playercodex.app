      "@context": "http://schema.org",
      "@type": "article",
      "name": "Earth Crystal - Stardew Valley Wiki",
      "headline": "Earth Crystal - Stardew Valley Wiki",
      "mainEntityOfPage": "Earth Crystal",
      "identifier": "https://stardewvalleywiki.com/Earth_Crystal",
